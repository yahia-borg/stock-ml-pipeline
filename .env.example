# Database (PostgreSQL + TimescaleDB)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stocks
DB_USER=postgres
DB_PASSWORD=stockpass

# API
API_PORT=8099

# FRED API (free — https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_api_key_here

# NewsAPI (free tier — https://newsapi.org/register)
NEWSAPI_KEY=your_newsapi_key_here

# vLLM endpoint (for LLM sentiment scoring)
VLLM_BASE_URL=http://localhost:8021/v1
VLLM_MODEL=your-model-name

# Weights & Biases (experiment tracking)
WANDB_API_KEY=your_wandb_key_here
WANDB_PROJECT=stock-forecast

# MLflow (optional, if using instead of W&B)
MLFLOW_TRACKING_URI=http://localhost:5000

# HuggingFace model cache (optional — defaults to ~/.cache/huggingface)
# Set this if you want models stored elsewhere (e.g., external drive)
# HF_HOME=/path/to/hf_cache

# Trained model output directory
MODELS_DIR=models
